# Copy this file to .env and fill in your real values.
# The .env file is gitignored — NEVER commit real credentials.

# --- Server ---
PORT=3000

# --- Supabase (from Min's Supabase project) ---
# Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- JWT ---
# Long random string. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- bcrypt ---
# Cost factor. 10 is a sensible default (higher = slower but more secure)
BCRYPT_SALT_ROUNDS=10
